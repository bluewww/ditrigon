<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 0.96.3 -->
<interface>
  <!-- interface-name notify-add-dialog.ui -->
  <requires lib="gtk" version="4.0"/>
  <object class="GtkWindow" id="notify_add_window">
    <property name="child">
      <object class="GtkBox" id="notify_add_root">
        <property name="margin-bottom">12</property>
        <property name="margin-end">12</property>
        <property name="margin-start">12</property>
        <property name="margin-top">12</property>
        <property name="orientation">vertical</property>
        <property name="spacing">8</property>
        <child>
          <object class="GtkLabel" id="notify_add_name_label">
            <property name="label" translatable="yes">Nickname:</property>
            <property name="xalign">0</property>
          </object>
        </child>
        <child>
          <object class="GtkEntry" id="notify_add_name_entry"/>
        </child>
        <child>
          <object class="GtkLabel" id="notify_add_network_label">
            <property name="label" translatable="yes">Networks (comma separated, leave empty for all):</property>
            <property name="xalign">0</property>
          </object>
        </child>
        <child>
          <object class="GtkEntry" id="notify_add_network_entry"/>
        </child>
        <child>
          <object class="GtkBox" id="notify_add_buttons">
            <property name="halign">end</property>
            <property name="orientation">horizontal</property>
            <property name="spacing">6</property>
            <child>
              <object class="GtkButton" id="notify_add_cancel_button">
                <property name="label" translatable="yes">Cancel</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="notify_add_ok_button">
                <property name="label" translatable="yes">Add</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
    <property name="default-height">180</property>
    <property name="default-width">420</property>
    <property name="modal">True</property>
    <property name="title" translatable="yes">Add to Friends List</property>
  </object>
</interface>
